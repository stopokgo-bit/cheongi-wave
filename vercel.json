{
  "version": 2,
  "functions": {
    "api/saju.js": {
      "maxDuration": 60
    },
    "api/og-image.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/og-image.png", "dest": "/api/og-image" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
